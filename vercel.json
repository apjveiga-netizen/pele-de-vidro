{
  "cleanUrls": true,
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/app", "dest": "/index.html" },
    { "src": "/login", "dest": "/index.html" },
    { "src": "/dashboard", "dest": "/index.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
